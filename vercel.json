{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/admin/login", "destination": "/api/index" },
    { "source": "/admin/logout", "destination": "/api/index" },
    { "source": "/admin/api/:path*", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "0 7 */5 * *"
    }
  ]
}
