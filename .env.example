PORT=3000
NODE_ENV=production

# ---- Supabase (Settings > API sayfasından kopyalayın) ----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ... (service_role key — sadece sunucuda kullanılır)

# ---- Admin paneli ----
ADMIN_USERNAME=admin
# Bcrypt hash (üretmek için: node scripts/hash-password.js "ParolanizBuraya")
ADMIN_PASSWORD_HASH=$2a$12$...

# ---- Güvenlik ----
# Rastgele 64+ karakter: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cok-uzun-ve-rastgele-bir-string-buraya

# TC hash'leme için salt: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TC_HASH_SALT=rastgele-64-karakter-hex
