PORT=3000

# Supabase (Settings > API sayfasından kopyalayın)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ... (service_role key — sadece sunucuda kullanılır)

# Admin paneli
ADMIN_USERNAME=admin
ADMIN_PASSWORD=degistir-beni

# JWT imzalama anahtarı (uzun ve rastgele olsun)
JWT_SECRET=cok-uzun-ve-rastgele-bir-string-buraya
